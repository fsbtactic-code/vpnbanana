# Заполняется автоматически server/install.sh и bot/install.sh в /root/vpnbanana/.env.
# Этот файл - только справка по переменным. Реальный .env (chmod 600) не коммитить.

# --- узел (генерится server/install.sh) ---
DOMAIN=
SERVER_IP=
HY_MAIN_PORT=443
HY_TURBO_PORT=8444
REALITY_PORT=8443
XHTTP_NL_PORT=8091
BACKEND_PORT=8090
HY_MAIN_STATS_PORT=9443
HY_TURBO_STATS_PORT=9444
REALITY_SNI=www.samsung.com
REALITY_FLOW=xtls-rprx-vision
REALITY_FP=firefox
REALITY_PBK=
REALITY_PRIV=
REALITY_SID=
XHTTP_PATH=
OBFS_PASSWORD=
HY_STATIC_PASSWORD=
HYSTERIA_STATS_SECRET=
OWNER_UUID=
LEGACY_HY_MAIN=
LEGACY_HY_TURBO=
PROFILE_TITLE=BananaVPN
SUPPORT_URL=
MASQ_URL=https://www.samsung.com/

# --- бот ---
BOT_TOKEN=
ADMIN_ID=
DB_PATH=/root/vpnbanana/bot/db.sqlite
XRAY_CONFIG=/usr/local/etc/xray/config.json
XRAY_API=127.0.0.1:10085
HY_MAIN_STATS=http://127.0.0.1:9443
HY_TURBO_STATS=http://127.0.0.1:9444

# --- узел XHTTP+CDN (Cloudflare), пусто = выключен ---
CF_HOST=
CF_DE_HOST=
PL_XHTTP_ALT_PORT=2053

# --- вторая локация, пусто = выключена (server/add-location.sh печатает значения) ---
PL_ENABLED=
PL_HOST=
PL_SSH_HOST=
PL_REALITY_PORT=443
PL_REALITY_PBK=
PL_REALITY_PRIV=
PL_REALITY_SID=
PL_REALITY_SNI=www.samsung.com
PL_OBFS_PASSWORD=
PL_STATS_SECRET=
PL_HY_MAIN_PORT=443
PL_HY_TURBO_PORT=8444
PL_XHTTP_PORT=8443
